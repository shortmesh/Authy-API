# OTP Configuration
# Length of generated OTP codes (default: 6)
OTP_LENGTH=6
# OTP expiry time in minutes (default: 10)
OTP_EXPIRY_MINUTES=10
# Maximum verification attempts before OTP is deleted (default: 3)
OTP_MAX_ATTEMPTS=3
# OTP message template (default: "Your verification code is {{code}}. It will expire on {{expiry}}.")
OTP_MESSAGE_TEMPLATE=Your verification code is {{code}}. It will expire on {{expiry}}.
# OTP cleanup job interval (default: 10m, format: duration string like "1h", "30m", "2h30m")
OTP_CLEANUP_INTERVAL=15m
